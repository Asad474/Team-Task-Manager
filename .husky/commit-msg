# Husky hooks setup

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Regular expression for conventional commits
# Supports: feat, fix, chore, docs, style, refactor, perf, test
pattern="^(feat|fix|chore|docs|style|refactor|perf|test)(\(.+\))?: .+"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "Error: Invalid commit message format."
  echo "Commit messages must follow the conventional commits format:"
  echo "  <type>(<scope>): <description>"
  echo "Example: feat(auth): add login functionality"
  echo "Types allowed: feat, fix, chore, docs, style, refactor, perf, test"
  exit 1
fi
