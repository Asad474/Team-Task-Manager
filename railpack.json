{
  "steps": {
    "build": {
      "workingDirectory": "backend",
      "commands": ["npm install", "npm run build"]
    }
  },
  "deploy": {
    "startCommand": "cd backend && node dist/server.js",
    "inputs": [
      {
        "step": "build",
        "include": ["backend/dist/**"]
      }
    ]
  }
}